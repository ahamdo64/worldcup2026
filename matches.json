# ==========================================
# دوال مساعدة
# ==========================================

def get_flag(team_name):
    """الحصول على علم الفريق"""
    return FLAGS.get(team_name, '⚽')

def get_arabic_name(team_name):
    """الحصول على الاسم العربي"""
    return ARABIC_NAMES.get(team_name, team_name)

def get_stage_name(stage):
    """تحويل مرحلة المباراة إلى اسم عربي"""
    stages = {
        'GROUP_STAGE': 'دور المجموعات',
        'ROUND_OF_32': 'دور الـ 32',
        'ROUND_OF_16': 'دور الـ 16',
        'QUARTER_FINALS': 'ربع النهائي',
        'SEMI_FINALS': 'نصف النهائي',
        'FINAL': 'النهائي',
        'THIRD_PLACE': 'المركز الثالث'
    }
    return stages.get(stage, stage)

def fetch_from_api():
    """جلب المباريات من football-data.org API"""
    print("🌐 جاري الاتصال بـ football-data.org API...")
    
    headers = {"X-Auth-Token": API_KEY}
    all_matches = []
    
    # محاولة جلب من عدة مصادر
    competitions_to_try = [
        ('WC', 'كأس العالم'),
        ('WC2026', 'كأس العالم 2026'),
    ]
    
    for code, name in competitions_to_try:
        try:
            url = f"{BASE_URL}/competitions/{code}/matches"
            print(f"  🔍 محاولة: {name} ({code})")
            
            response = requests.get(url, headers=headers, timeout=15)
            
            if response.status_code == 200:
                data = response.json()
                matches = data.get('matches', [])
                print(f"  ✅ تم العثور على {len(matches)} مباراة")
                
                for match in matches:
                    if match.get('status') == 'FINISHED':
                        home_team = match.get('homeTeam', {}).get('name', '')
                        away_team = match.get('awayTeam', {}).get('name', '')
                        home_score = match.get('score', {}).get('fullTime', {}).get('home')
                        away_score = match.get('score', {}).get('fullTime', {}).get('away')
                        
                        if home_score is not None and away_score is not None:
                            all_matches.append({
                                'date': match.get('utcDate', '')[:10],
                                'team1': home_team,
                                'score1': home_score,
                                'team2': away_team,
                                'score2': away_score,
                                'stage': match.get('stage', 'GROUP_STAGE'),
                                'group': match.get('group', ''),
                                'utcDate': match.get('utcDate', ''),
                                'venue': match.get('venue', 'غير محدد'),
                                'matchday': match.get('matchday', ''),
                                'referees': match.get('referees', [{}])[0].get('name', '') if match.get('referees') else ''
                            })
                break
            else:
                print(f"  ⚠️ الحالة: {response.status_code}")
                
        except Exception as e:
            print(f"  ❌ خطأ: {e}")
    
    return all_matches

def merge_matches(local_matches, api_matches):
    """دمج المباريات المحلية مع مباريات API"""
    print("\n🔄 جاري دمج المباريات...")
    
    # استخدام القاموس لتجنب التكرار (المفتاح: التاريخ + الفريقين)
    matches_dict = {}
    
    # إضافة المباريات المحلية أولاً
    for m in local_matches:
        key = f"{m['date']}_{m['team1']}_{m['team2']}"
        matches_dict[key] = m
    
    # إضافة/تحديث من API
    added_count = 0
    updated_count = 0
    for m in api_matches:
        key = f"{m['date']}_{m['team1']}_{m['team2']}"
        if key in matches_dict:
            # تحديث إذا كانت البيانات من API أحدث
            if 'utcDate' in m and m['utcDate']:
                matches_dict[key] = m
                updated_count += 1
        else:
            matches_dict[key] = m
            added_count += 1
    
    print(f"  ✅ محلي: {len(local_matches)} مباراة")
    print(f"  🌐 من API: {len(api_matches)} مباراة")
    print(f"  ➕ تمت إضافة: {added_count} مباراة جديدة")
    print(f"  🔄 تم تحديث: {updated_count} مباراة")
    
    return list(matches_dict.values())

def process_matches(matches):
    """معالجة المباريات وإخراجها بالصيغة المطلوبة"""
    print("\n📝 جاري معالجة المباريات...")
    
    processed = []
    finished_count = 0
    total_goals = 0
    
    for m in matches:
        # تحديد الحالة
        status = 'finished'
        status_text = '✅ انتهت'
        
        # تنسيق النتيجة
        score = f"{m['score1']} - {m['score2']}"
        total_goals += m['score1'] + m['score2']
        finished_count += 1
        
        # الأعلام
        home_flag = get_flag(m['team1'])
        away_flag = get_flag(m['team2'])
        
        # الوقت من utcDate
        time_str = '20:00'
        utc_date = m.get('utcDate', '')
        if utc_date and 'T' in utc_date:
            time_str = utc_date.split('T')[1][:5]
        
        processed.append({
            'group': m.get('group', 'كأس العالم 2026'),
            'date': m['date'],
            'time': time_str,
            'team1': f"{home_flag} {m['team1']}",
            'team2': f"{away_flag} {m['team2']}",
            'homeTeam': m['team1'],
            'awayTeam': m['team2'],
            'homeTeamAr': get_arabic_name(m['team1']),
            'awayTeamAr': get_arabic_name(m['team2']),
            'score': score,
            'homeScore': m['score1'],
            'awayScore': m['score2'],
            'status': status,
            'statusText': status_text,
            'stage': m.get('stage', 'GROUP_STAGE'),
            'stageName': get_stage_name(m.get('stage', 'GROUP_STAGE')),
            'utcDate': utc_date or f"{m['date']}T20:00:00Z",
            'competition': 'FIFA World Cup 2026',
            'matchday': m.get('matchday', ''),
            'venue': m.get('venue', 'غير محدد'),
            'referees': m.get('referees', '')
        })
    
    # ترتيب حسب التاريخ
    processed.sort(key=lambda x: x['utcDate'])
    
    print(f"  ✅ عدد المباريات المنتهية: {finished_count}")
    print(f"  ⚽ إجمالي الأهداف: {total_goals}")
    print(f"  📊 معدل الأهداف/مباراة: {total_goals/finished_count:.2f}")
    
    return processed, finished_count, total_goals

def save_to_json(matches, stats):
    """حفظ البيانات في ملف JSON"""
    output = {
        'lastUpdate': datetime.now().isoformat(),
        'totalMatches': stats['total'],
        'finishedMatchesCount': stats['finished'],
        'liveMatchesCount': 0,
        'upcomingMatchesCount': 0,
        'totalGoals': stats['goals'],
        'averageGoals': round(stats['goals'] / stats['finished'], 2) if stats['finished'] > 0 else 0,
        'tournamentStage': 'نصف النهائي',
        'remainingTeams': ['France', 'Spain', 'Argentina', 'England'],
        'remainingTeamsAr': ['فرنسا 🇫🇷', 'إسبانيا 🇪🇸', 'الأرجنتين 🇦🇷', 'إنجلترا 🏴󠁧󠁢󠁥󠁮󠁧󠁿'],
        'matches': matches
    }
    
    with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:
        json.dump(output, f, ensure_ascii=False, indent=2)
    
    print(f"\n💾 تم حفظ الملف: {OUTPUT_FILE}")
    print(f"  📄 الحجم: {os.path.getsize(OUTPUT_FILE) / 1024:.2f} KB")

def generate_report(matches):
    """توليد تقرير نصي"""
    print("\n📊 التقرير:")
    print("=" * 60)
    
    # ترتيب حسب المرحلة
    stages_order = ['GROUP_STAGE', 'ROUND_OF_32', 'ROUND_OF_16', 'QUARTER_FINALS', 'SEMI_FINALS']
    
    for stage in stages_order:
        stage_matches = [m for m in matches if m.get('stage') == stage]
        if stage_matches:
            print(f"\n🏆 {get_stage_name(stage)} ({len(stage_matches)} مباراة):")
            print("-" * 60)
            for m in stage_matches:
                print(f"  {m['date']} | {m['team1']} {m['score']} {m['team2']}")

def main():
    """الدالة الرئيسية"""
    print("=" * 60)
    print("🏆 سكريبت جلب نتائج كأس العالم 2026")
    print("=" * 60)
    print(f"📅 التاريخ: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    
    # 1. جلب من API
    api_matches = fetch_from_api()
    
    # 2. دمج مع البيانات المحلية
    all_matches = merge_matches(LOCAL_MATCHES, api_matches)
    
    # 3. معالجة
    processed, finished_count, total_goals = process_matches(all_matches)
    
    # 4. حفظ
    stats = {
        'total': len(processed),
        'finished': finished_count,
        'goals': total_goals
    }
    save_to_json(processed, stats)
    
    # 5. تقرير
    generate_report(processed)
    
    print("\n" + "=" * 60)
    print("✅ تم بنجاح!")
    print("=" * 60)
